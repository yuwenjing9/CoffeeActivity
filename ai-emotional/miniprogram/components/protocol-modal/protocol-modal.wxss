.pm-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
}

.pm-panel {
  width: 100%;
  background: #fff;
  border-radius: 28rpx;
  padding: 40rpx 36rpx 32rpx;
}

.pm-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1F1B16;
  margin-bottom: 24rpx;
}

.pm-desc {
  font-size: 26rpx;
  color: #5A5450;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.pm-list {
  margin-bottom: 18rpx;
}

.pm-item {
  font-size: 26rpx;
  color: #5A5450;
  line-height: 1.8;
}

.pm-tip {
  font-size: 24rpx;
  color: #5A5450;
  line-height: 1.7;
  margin-bottom: 28rpx;
}

.pm-link {
  color: var(--primary);
}

.pm-agree {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0 28rpx;
}

.pm-check {
  width: 32rpx;
  height: 32rpx;
  border-radius: 6rpx;
  border: 2rpx solid #9C948D;
  background: #fff;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pm-check.on {
  background: var(--primary);
  border-color: var(--primary);
}

.pm-check-icon {
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
}

.pm-agree-text {
  font-size: 26rpx;
  color: #1F1B16;
}

.pm-actions {
  display: flex;
  gap: 20rpx;
}

.pm-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
}

.pm-btn-ghost {
  background: #fff;
  border: 2rpx solid #E8E2D8;
  color: #1F1B16;
}

.pm-btn-primary {
  background: var(--primary);
  color: #fff;
}

.pm-btn-primary.dis {
  background: #FFC9AC;
}