.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #FFFFFF;
  display: flex;
  z-index: 999;
}

.tab-bar-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background-color: rgba(0, 0, 0, 0.06);
  transform: scaleY(0.5);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 6rpx;
}

.emoji {
  font-size: 40rpx;
  line-height: 1;
  margin-bottom: 4rpx;
  filter: grayscale(0.6);
  transition: filter 0.2s;
}

.emoji.active {
  filter: grayscale(0);
}

.label {
  font-size: 22rpx;
  line-height: 1.4;
}