/* 全局样式：AI 情绪小伙伴 */
page {
  --primary: #FF7A3D;
  --accent: #7C5CFF;
  --bg: #F4F1EC;
  --card: #FFFFFF;
  --text: #2A2A2A;
  --text-2: #666666;
  --text-3: #999999;
  --border: #ECE7E0;
  --danger: #E94B3C;
  --success: #2BB673;
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 0 30rpx 40rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 999rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
}

.btn-ghost {
  background: #fff;
  color: var(--text);
  border: 1rpx solid var(--border);
  border-radius: 999rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
}

.flex-row {
  display: flex;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

.mt-16 {
  margin-top: 16rpx;
}

.mt-24 {
  margin-top: 24rpx;
}

.mt-32 {
  margin-top: 32rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.row.no-bd {
  border-bottom: 0;
}

.row-k {
  color: var(--text);
  font-size: 28rpx;
}

.row-sub {
  color: var(--text-3);
  font-size: 26rpx;
  margin-right: 8rpx;
}

.row-arrow {
  color: var(--text-3);
  font-size: 32rpx;
}