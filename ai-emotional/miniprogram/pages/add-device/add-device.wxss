.add-page {
  padding-top: 24rpx;
}

.big-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F1B16;
  margin-bottom: 8rpx;
}

.hint {
  font-size: 24rpx;
  color: #9C948D;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F1B16;
  margin-bottom: 16rpx;
}

/* ========== step 1：配网准备 ========== */
.prep-illust {
  display: flex;
  justify-content: center;
  padding: 48rpx 0 32rpx;
}

.prep-rabbit {
  width: 320rpx;
  height: 320rpx;
}

.prep-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F1B16;
  text-align: center;
  margin-top: 8rpx;
}

.prep-desc {
  font-size: 28rpx;
  color: #5A5450;
  text-align: center;
  line-height: 1.7;
  margin-top: 16rpx;
  padding: 0 48rpx;
}

.prep-num {
  color: var(--primary);
  font-weight: 600;
}

.prep-highlight {
  color: #3DA1FF;
  font-weight: 500;
}

.prep-tip-card {
  display: flex;
  align-items: flex-start;
  background: #FFF8F0;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin: 40rpx 32rpx 0;
}

.prep-tip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.prep-tip-text {
  font-size: 26rpx;
  color: #5A5450;
  line-height: 1.6;
  flex: 1;
}

.prep-tip-bold {
  color: #1F1B16;
  font-weight: 600;
}

.prep-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #F4F1EC;
  z-index: 10;
}

/* 遮罩层 */
.mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.45);
}

/* 蓝牙弹层 */
.ble-modal {
  position: fixed;
  left: 48rpx;
  right: 48rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #fff;
  border-radius: 28rpx;
  padding: 48rpx 36rpx 32rpx;
}

.ble-icon {
  font-size: 80rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.ble-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.ble-desc {
  font-size: 26rpx;
  color: #5A5450;
  line-height: 1.7;
  margin-bottom: 32rpx;
}

.ble-actions {
  display: flex;
  gap: 20rpx;
}

.pm-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  text-align: center;
  font-size: 30rpx;
}

.pm-btn-ghost {
  background: #fff;
  border: 2rpx solid #E8E2D8;
  color: #1F1B16;
}

.pm-btn-primary {
  background: var(--primary);
  color: #fff;
}

/* ========== step 3：扫描 ========== */
.scan-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.scan-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F1B16;
  margin-bottom: 8rpx;
}

.scan-card-hint {
  font-size: 24rpx;
  color: #9C948D;
}

/* 雷达 */
.radar {
  position: relative;
  width: 100%;
  height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
}

.radar-ring {
  position: absolute;
  width: 100rpx;
  height: 100rpx;
  border: 2rpx solid var(--primary);
  border-radius: 50%;
  opacity: 0;
  animation: radar 2.5s ease-out infinite;
}

.ring1 {
  animation-delay: 0s;
}

.ring2 {
  animation-delay: 0.8s;
}

.ring3 {
  animation-delay: 1.6s;
}

@keyframes radar {
  0%   { transform: scale(1); opacity: 0.5; }
  100% { transform: scale(3); opacity: 0; }
}

.radar-core {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD7BE 0%, var(--primary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  overflow: hidden;
}

.radar-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.scanning {
  text-align: center;
  color: #9C948D;
  font-size: 26rpx;
  margin-top: 16rpx;
}

/* 设备列表卡片 */
.scan-list-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-top: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.scan-list-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F1B16;
  margin-bottom: 16rpx;
}

/* flex 辅助 */
.flex-1 {
  flex: 1;
  min-width: 0;
}

/* 扫描结果 item */
.scan-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F4F1EC;
}

.scan-item:last-child {
  border-bottom: none;
}

.scan-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FFE7D9;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.scan-name {
  font-size: 30rpx;
  color: #1F1B16;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scan-sub {
  font-size: 22rpx;
  color: #9C948D;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scan-rssi {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.rssi-bar {
  width: 60rpx;
  height: 6rpx;
  background: #E8E2D8;
  border-radius: 3rpx;
  margin-bottom: 6rpx;
  overflow: hidden;
}

.rssi-bar-inner {
  height: 100%;
  border-radius: 3rpx;
}

.rssi-bar.strong .rssi-bar-inner { background: #34C759; }
.rssi-bar.medium .rssi-bar-inner { background: #FF7A3D; }
.rssi-bar.weak .rssi-bar-inner { background: #E94B3C; }

.scan-rssi-text {
  font-size: 22rpx;
  color: #5A5450;
}

.scan-rescan-btn {
  height: 88rpx;
  line-height: 88rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  text-align: center;
  font-size: 30rpx;
  color: #1F1B16;
  margin-top: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.scan-rescan-btn.disabled {
  color: #9C948D;
}

/* 表单 */
.form-item {
  margin-top: 24rpx;
}

.form-label {
  font-size: 24rpx;
  color: #5A5450;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F4F1EC;
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1F1B16;
}

.form-input-row {
  display: flex;
  align-items: center;
  background: #F4F1EC;
  border-radius: 14rpx;
  padding-right: 16rpx;
}

.form-input-row .form-input {
  background: transparent;
}

.form-eye {
  padding: 0 16rpx;
  font-size: 32rpx;
}

.form-error {
  font-size: 22rpx;
  color: var(--danger);
  margin-top: 10rpx;
}

.tip-box {
  background: #FFF6EE;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: #B96A2F;
  line-height: 1.6;
}

/* 配网进度 */
.prov-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.prov-item {
  display: flex;
  align-items: center;
}

.prov-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #E8E2D8;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}

.prov-dot.doing {
  background: var(--primary);
}

.prov-dot.done {
  background: #34C759;
}

.prov-text {
  color: #9C948D;
  font-size: 28rpx;
}

.prov-text.doing {
  color: #1F1B16;
  font-weight: 500;
}

.prov-text.done {
  color: #1F1B16;
}

.prov-spin {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  border-top-color: #fff;
  animation: lt-spin 0.8s linear infinite;
}

@keyframes lt-spin {
  to {
    transform: rotate(360deg);
  }
}

/* ========== step 5：配网中 ========== */
.prov-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F1B16;
  text-align: center;
  margin-top: 32rpx;
}

.prov-sub {
  font-size: 26rpx;
  color: #9C948D;
  text-align: center;
  margin-top: 12rpx;
  margin-bottom: 40rpx;
}

.prov-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin: 0 32rpx;
  padding: 8rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.prov-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F4F1EC;
}

.prov-row:last-child {
  border-bottom: none;
}

.prov-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  font-size: 22rpx;
}

.prov-icon.done {
  background: #34C759;
  color: #FFFFFF;
}

.prov-icon.doing {
  background: var(--primary);
  color: #FFFFFF;
}

.prov-icon.wait {
  background: #E8E2D8;
  color: #FFFFFF;
}

.prov-spin-sm {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  border-top-color: #fff;
  animation: lt-spin 0.8s linear infinite;
}

.prov-dot-sm {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #E8E2D8;
}

.prov-label {
  flex: 1;
  font-size: 28rpx;
}

.prov-label.done {
  color: #1F1B16;
}

.prov-label.doing {
  color: #1F1B16;
  font-weight: 500;
}

.prov-label.wait {
  color: #9C948D;
}

.prov-timer {
  font-size: 26rpx;
  color: var(--primary);
  margin-left: 16rpx;
}

/* ========== step 6：绑定成功 ========== */
.success-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 48rpx;
  margin-bottom: 40rpx;
}

.success-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #E8F5E9;
  color: #34C759;
  font-size: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.success-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F1B16;
  margin-bottom: 12rpx;
}

.success-sub {
  font-size: 26rpx;
  color: #9C948D;
}

.nickname-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 32rpx 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.nickname-label {
  font-size: 24rpx;
  color: #9C948D;
  margin-bottom: 12rpx;
}

.nickname-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nickname-input {
  font-size: 32rpx;
  color: #1F1B16;
  font-weight: 500;
  padding: 0;
  background: transparent;
  flex: 1;
}

.nickname-edit {
  font-size: 26rpx;
  color: var(--primary);
  margin-left: 16rpx;
  flex-shrink: 0;
}

.info-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 32rpx;
  padding: 8rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F4F1EC;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #1F1B16;
}

.info-label.gray {
  color: #9C948D;
}

.info-value {
  font-size: 26rpx;
  color: #1F1B16;
  font-weight: 500;
}

.success-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #F4F1EC;
  z-index: 10;
}

.success-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 24rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: var(--primary);
}

/* ========== step 4：配置 Wi-Fi ========== */
.add-page {
  padding-bottom: 180rpx;
}

.wifi-conn-card {
  display: flex;
  align-items: center;
  background: #E8F5E9;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin: 24rpx 32rpx 24rpx;
}

.wifi-conn-check {
  color: #34C759;
  font-size: 32rpx;
  font-weight: 700;
  margin-right: 16rpx;
}

.wifi-conn-text {
  font-size: 30rpx;
  color: #34C759;
  font-weight: 500;
}

/* Wi-Fi 配网提示卡片 */
.wifi-hint-card {
  display: flex;
  align-items: flex-start;
  background: #FFF8F0;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin: 24rpx 32rpx 24rpx;
}

.wifi-hint-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.wifi-hint-content {
  flex: 1;
}

.wifi-hint-text {
  font-size: 26rpx;
  color: #5A5450;
  line-height: 1.6;
}

.wifi-hint-bold {
  color: #1F1B16;
  font-weight: 600;
}

.wifi-section-title {
  font-size: 24rpx;
  color: #9C948D;
  margin: 0 32rpx 16rpx;
}

.wifi-form-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin: 0 32rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.wifi-form-label {
  font-size: 24rpx;
  color: #9C948D;
  margin-bottom: 12rpx;
}

/* Wi-Fi 列表 */
.wifi-list-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 32rpx 20rpx;
  padding: 8rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.wifi-list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F4F1EC;
}

.wifi-list-item:last-child {
  border-bottom: none;
}

.wifi-list-info {
  flex: 1;
  min-width: 0;
}

.wifi-list-name {
  font-size: 30rpx;
  color: #1F1B16;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.wifi-list-band {
  font-size: 22rpx;
  display: inline-block;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.wifi-list-band.green {
  background: #E8F5E9;
  color: #34C759;
}

.wifi-list-band.red {
  background: #FFF0EE;
  color: #E94B3C;
}

.wifi-list-signal {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.wifi-signal-bars {
  display: flex;
  align-items: flex-end;
  gap: 3rpx;
  height: 20rpx;
  margin-bottom: 4rpx;
}

.wifi-signal-bar {
  width: 5rpx;
  background: #E8E2D8;
  border-radius: 1rpx;
}

.wifi-signal-bar:nth-child(1) { height: 6rpx; }
.wifi-signal-bar:nth-child(2) { height: 10rpx; }
.wifi-signal-bar:nth-child(3) { height: 14rpx; }
.wifi-signal-bar:nth-child(4) { height: 18rpx; }

.wifi-signal-bar.on {
  background: var(--primary);
}

.wifi-signal-text {
  font-size: 20rpx;
  color: #9C948D;
}

.wifi-list-connected {
  font-size: 22rpx;
  color: #34C759;
  margin-left: 12rpx;
  font-weight: 400;
}

/* Wi-Fi 空状态 */
.wifi-empty-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 32rpx 20rpx;
  padding: 60rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.wifi-empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.wifi-empty-text {
  font-size: 28rpx;
  color: #1F1B16;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.wifi-empty-hint {
  font-size: 24rpx;
  color: #9C948D;
  margin-bottom: 24rpx;
}

.wifi-empty-retry {
  font-size: 26rpx;
  color: var(--primary);
  padding: 12rpx 32rpx;
  border: 2rpx solid var(--primary);
  border-radius: 24rpx;
}

.wifi-form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.wifi-form-value {
  font-size: 32rpx;
  color: #1F1B16;
  font-weight: 500;
  height: 52rpx;
  line-height: 52rpx;
}

.wifi-form-input {
  font-size: 32rpx;
  color: #1F1B16;
  font-weight: 500;
  padding: 0;
  background: transparent;
  height: 52rpx;
  line-height: 52rpx;
  flex: 1;
}

.wifi-form-action {
  font-size: 26rpx;
  color: var(--primary);
  margin-left: 16rpx;
  flex-shrink: 0;
}

.wifi-form-eye {
  font-size: 32rpx;
  color: #9C948D;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.wifi-form-tag {
  font-size: 22rpx;
  margin-top: 12rpx;
}

.wifi-form-tag.green {
  color: #34C759;
}

.wifi-form-tag.red {
  color: var(--danger);
}

.wifi-tip-card {
  background: #FFF6EE;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin: 0 32rpx 32rpx;
}

.wifi-tip-label {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.wifi-tip-body {
  font-size: 24rpx;
  color: #B96A2F;
  line-height: 1.5;
}

.wifi-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #F4F1EC;
  z-index: 10;
}

.wifi-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 24rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: var(--primary);
}

.wifi-btn.disabled {
  background: #FFC9AC;
}

/* ========== 5GHz 拦截 ========== */
.wifi-5g-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin: 0 32rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #FFE0DB;
}

.wifi-5g-label {
  font-size: 24rpx;
  color: #E94B3C;
  margin-bottom: 12rpx;
}

.wifi-5g-value {
  font-size: 32rpx;
  color: #1F1B16;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.wifi-5g-error {
  font-size: 24rpx;
  color: #E94B3C;
}

.wifi-5g-pwd-card {
  background: #FFFFFF;
  border-radius: 24rpx;
