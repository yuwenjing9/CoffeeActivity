<view class="page pf-page">

  <!-- 用户卡片 -->
  <view class="pf-user card mt-16">
    <button
      class="pf-avatar-btn"
      open-type="chooseAvatar"
      bindchooseavatar="onChooseAvatar"
      hover-class="none"
    >
      <view class="pf-avatar">
        <image wx:if="{{user.avatarUrl}}" src="{{user.avatarUrl}}" class="pf-img" mode="aspectFill" />
        <text wx:else class="pf-emoji">😊</text>
      </view>
    </button>
    <view class="flex-1">
      <input
        class="pf-name pf-name-input"
        type="nickname"
        placeholder="点击使用微信昵称"
        placeholder-class="pf-name-ph"
        value="{{user.nickName}}"
        bindblur="onNickChange"
        bindchange="onNickChange"
      />
      <view class="pf-meta">微信账号 · {{ user.avatarUrl ? '已绑定 ' + deviceCount + ' 台设备' : '点击头像设置微信头像' }}</view>
    </view>
  </view>

  <!-- 账号 -->
  <view class="pf-group">
    <view class="pf-group-title">账号</view>
    <view class="card">
      <view class="row" data-url="/pages/profile/profile" bindtap="goPage">
        <text class="row-k">个人资料</text>
        <text class="row-arrow">›</text>
      </view>
      <view class="row no-bd" data-url="tab:/pages/device/device" bindtap="goPage">
        <text class="row-k">我的设备</text>
        <view class="flex-row">
          <text class="row-sub">{{deviceCount}} 台</text>
          <text class="row-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 隐私与协议 -->
  <view class="pf-group">
    <view class="pf-group-title">隐私与协议</view>
    <view class="card">
      <view class="row" data-url="/pages/privacy/privacy" bindtap="goPage">
        <text class="row-k">隐私设置</text>
        <text class="row-arrow">›</text>
      </view>
      <view class="row" data-url="/pages/webview/webview?type=user" bindtap="goPage">
        <text class="row-k">用户协议</text>
        <text class="row-arrow">›</text>
      </view>
      <view class="row no-bd" data-url="/pages/webview/webview?type=privacy" bindtap="goPage">
        <text class="row-k">隐私政策</text>
        <text class="row-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 支持 -->
  <view class="pf-group">
    <view class="pf-group-title">支持</view>
    <view class="card">
      <view class="row" bindtap="onCall">
        <text class="row-k">联系客服</text>
        <text class="row-sub">400-123-4567 <text class="row-arrow">›</text></text>
      </view>
      <view class="row" data-url="/pages/webview/webview?type=help" bindtap="goPage">
        <text class="row-k">帮助中心</text>
        <text class="row-arrow">›</text>
      </view>
      <view class="row no-bd" data-url="/pages/about/about" bindtap="goPage">
        <text class="row-k">关于小伙伴</text>
        <view class="flex-row">
          <text class="row-sub">v{{version}}</text>
          <text class="row-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <view class="logout" bindtap="onLogout">退出登录</view>
</view>
