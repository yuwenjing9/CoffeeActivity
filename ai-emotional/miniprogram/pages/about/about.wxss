.ab-page {
  padding-top: 24rpx;
  padding-bottom: 60rpx;
}

.ab-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 24rpx;
}

.ab-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #FFD7BE 0%, var(--primary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 90rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(255, 122, 61, 0.3);
}

.ab-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F1B16;
}

.ab-ver {
  font-size: 24rpx;
  color: #9C948D;
  margin-top: 8rpx;
}

.pf-group {
  margin-top: 24rpx;
}

.pf-group-title {
  font-size: 24rpx;
  color: #9C948D;
  padding: 0 12rpx 12rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F4F1EC;
}

.row.no-bd {
  border-bottom: none;
}

.row-k {
  font-size: 28rpx;
  color: #1F1B16;
}

.row-sub {
  font-size: 24rpx;
  color: #9C948D;
}

.row-arrow {
  color: #9C948D;
  font-size: 36rpx;
  margin-left: 10rpx;
}

.ab-foot {
  text-align: center;
  color: #9C948D;
  font-size: 22rpx;
  margin-top: 60rpx;
}