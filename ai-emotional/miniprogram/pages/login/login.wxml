<view class="login-page" style="padding-top: {{statusBarHeight + 20}}px;">

  <!-- Hero 卡片：四周悬浮 -->
  <view class="hero">
    <view class="hero-avatar-ring">
      <view class="hero-avatar">
        <text class="hero-emoji">🐰</text>
      </view>
    </view>
    <view class="hero-title">主人，你好！</view>
    <view class="hero-sub">我是你的AI情绪小伙伴</view>
  </view>

  <!-- 登录按钮 -->
  <view class="login-actions">
    <button class="login-btn" bindtap="onLogin">
      <text class="login-icon">💬</text>
      <text>{{logining ? '登录中...' : '微信一键登录'}}</text>
    </button>

    <view class="agree-row">
      <view class="check {{agreed ? 'on' : ''}}" catchtap="onToggleAgree">
        <text wx:if="{{agreed}}" class="check-tick">✓</text>
      </view>
      <text class="agree-text" catchtap="onToggleAgree">我已阅读并同意</text>
      <text class="link" catchtap="onLink" data-type="user">《用户协议》</text>
      <text class="agree-text">和</text>
      <text class="link" catchtap="onLink" data-type="privacy">《隐私政策》</text>
    </view>
  </view>

  <!-- 微信授权弹窗 -->
  <view class="auth-mask {{showAuth ? 'show' : ''}}" catchtap="onAuthDeny"></view>
  <view class="auth-sheet {{showAuth ? 'show' : ''}}" catchtap="">
    <view class="auth-title">「AI情绪小伙伴」申请获取你的微信信息</view>

    <view class="auth-card">
      <view class="auth-card-avatar">
        <text class="auth-card-emoji">😊</text>
      </view>
      <view class="auth-card-info">
        <input
          class="auth-card-name-input"
          type="nickname"
          placeholder="点击使用微信昵称"
          placeholder-class="auth-card-name-ph"
          value="{{wxNickName}}"
          bindinput="onNickInput"
          bindblur="onNickInput"
          bindchange="onNickInput"
        />
        <view class="auth-card-desc">头像 · 昵称 · 性别 · 地区</view>
      </view>
    </view>

    <view class="auth-tip">点击昵称栏使用微信昵称；用于注册账号与基础展示。</view>

    <view class="auth-actions">
      <button class="auth-btn deny" bindtap="onAuthDeny">拒绝</button>
      <button class="auth-btn allow" bindtap="onAuthAllow" loading="{{logining}}">允许</button>
    </view>
  </view>

  <!-- 隐私协议弹层 -->
  <protocol-modal
    visible="{{showProtocol}}"
    bind:agree="onProtocolAgree"
    bind:disagree="onProtocolDisagree"
  />
</view>
