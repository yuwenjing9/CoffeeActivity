.dev-page {
  padding-top: 40rpx;
}

.dev-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.dev-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1F1B16;
}

.dev-add {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #fff;
  border: 2rpx solid #E8E2D8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dev-add-plus {
  color: #1F1B16;
  font-size: 40rpx;
  font-weight: 300;
  line-height: 1;
}

.dev-list-item {
  margin-bottom: 20rpx;
}

.empty {
  margin-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 120rpx;
  box-shadow: 0 8rpx 30rpx rgba(31, 27, 22, 0.06);
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F1B16;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9C948D;
  margin-bottom: 48rpx;
  text-align: center;
}

.empty-btn {
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 100rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 21rpx;
  font-size: 28rpx;
}