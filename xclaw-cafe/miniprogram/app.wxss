/**app.wxss**/
page {
  background: #FAF8F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica', 'Arial', sans-serif;
  color: #333333;
  overflow-x: hidden;
  width: 100%;
  box-sizing: border-box;
}

/* 主色调变量 */
:root {
  --primary: #6B4423;
  --secondary: #C17817;
  --accent: #7A9E7E;
  --danger: #E54D42;
  --bg: #FAF8F5;
  --card: #FFFFFF;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-muted: #999999;
  --border: #EEEEEE;
}

/* 通用容器 */
.container {
  padding: 0 32rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
  color: #FFFFFF;
}

.btn-secondary {
  background: #F5F0EB;
  color: #6B4423;
}

.btn-ghost {
  background: transparent;
  border: 2rpx solid #6B4423;
  color: #6B4423;
}

.btn-disabled {
  background: #CCCCCC;
  color: #FFFFFF;
}

/* 文字样式 */
.text-primary { color: #333333; }
.text-secondary { color: #666666; }
.text-muted { color: #999999; }
.text-primary-color { color: #6B4423; }
.text-danger { color: #E54D42; }

.text-xl { font-size: 40rpx; font-weight: bold; }
.text-lg { font-size: 32rpx; font-weight: bold; }
.text-md { font-size: 28rpx; }
.text-sm { font-size: 24rpx; }
.text-xs { font-size: 22rpx; }

/* 价格样式 */
.price {
  color: #6B4423;
  font-weight: bold;
}

.price-lg {
  font-size: 40rpx;
}

.price-md {
  font-size: 32rpx;
}

.price-sm {
  font-size: 26rpx;
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.tag-primary {
  background: rgba(107, 68, 35, 0.1);
  color: #6B4423;
}

.tag-accent {
  background: rgba(122, 158, 126, 0.1);
  color: #7A9E7E;
}

.tag-danger {
  background: rgba(229, 77, 66, 0.1);
  color: #E54D42;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: #EEEEEE;
  margin: 24rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-state text {
  color: #999999;
  font-size: 28rpx;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* Flex布局 */
.flex { display: flex; }
.flex-column { flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }
.flex-center { justify-content: center; align-items: center; }
.flex-between { justify-content: space-between; align-items: center; }
.flex-around { justify-content: space-around; align-items: center; }
.align-center { align-items: center; }

/* 间距 */
.mt-8 { margin-top: 16rpx; }
.mt-12 { margin-top: 24rpx; }
.mt-16 { margin-top: 32rpx; }
.mb-8 { margin-bottom: 16rpx; }
.mb-12 { margin-bottom: 24rpx; }
.ml-8 { margin-left: 16rpx; }
.mr-8 { margin-right: 16rpx; }

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}
