<view class="dev-page page">

  <!-- 顶部 -->
  <view class="dev-header">
    <view class="dev-title" wx:if="{{devices.length > 0}}">我的灵兔（{{devices.length}}）</view>
    <view class="dev-title" wx:else>设备</view>
    <view class="dev-add" bindtap="onAdd">
      <text class="dev-add-plus">+</text>
    </view>
  </view>

  <!-- 列表 -->
  <view wx:if="{{devices.length > 0}}" class="dev-list">
    <view class="dev-list-item" wx:for="{{devices}}" wx:key="id">
      <device-card device="{{item}}" bind:tap="onCardTap" />
    </view>
  </view>

  <!-- 空态 -->
  <view wx:else class="empty">
    <view class="empty-icon">🐰</view>
    <view class="empty-title">还没有AI小伙伴陪伴你</view>
    <view class="empty-desc">
      <view>添加你的第一位AI小伙伴，</view>
      <view>开启你们的故事</view>
    </view>
    <view class="empty-btn" bindtap="onAdd">+ 添加设备</view>
  </view>
</view>