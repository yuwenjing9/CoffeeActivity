<!--index.wxml-->
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="header-content">
      <view class="header-text">
        <view class="header-title">鲜萃咖小站</view>
        <view class="header-subtitle">每一杯都是精心之作</view>
      </view>
      <view class="header-icon">
        <text class="icon-coffee">☕</text>
      </view>
    </view>
  </view>

  <!-- Banner轮播 -->
  <view class="banner-section">
    <swiper class="banner-swiper" indicator-dots="{{true}}" autoplay="{{true}}" interval="3000" duration="500" circular="{{true}}">
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <image class="banner-image" src="{{item.image}}" mode="aspectFill"/>
      </swiper-item>
    </swiper>
  </view>

  <!-- 快捷分类 -->
  <view class="category-section">
    <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="onCategoryTap" data-id="{{item.id}}">
      <view class="category-icon-wrapper">
        <text class="category-icon">{{item.emoji}}</text>
      </view>
      <view class="category-name">{{item.name}}</view>
    </view>
  </view>

  <!-- 限时优惠 -->
  <view class="promotion-section" bindtap="onPromotionTap">
    <view class="promotion-content">
      <view class="promotion-left">
        <image class="promotion-icon" src="/images/icons/coupon.png" mode="aspectFit"/>
        <view class="promotion-text">
          <view class="promotion-label">限时优惠</view>
          <view class="promotion-title">全场满50减10</view>
        </view>
      </view>
      <image class="promotion-arrow" src="/images/icons/arrow.png" mode="aspectFit"/>
    </view>
  </view>

  <!-- 推荐商品 -->
  <view class="recommend-section">
    <view class="section-header">
      <view class="section-left">
        <image class="section-icon" src="/images/icons/icon1.png" mode="aspectFit"/>
        <text class="section-title">精选推荐</text>
      </view>
      <view class="header-more" bindtap="onCategoryTap" data-id="1">
        <text class="more-text">更多</text>
        <image class="more-icon" src="/images/icons/arrow1.png" mode="aspectFit"/>
      </view>
    </view>

    <view class="product-grid">
      <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
        <view class="product-image-wrapper">
          <image class="product-image" src="{{item.image}}" mode="aspectFill"/>
          <view class="product-tag {{item.tagClass}}">{{item.tag}}</view>
        </view>
        <view class="product-info">
          <view class="product-name">{{item.name}}</view>
          <view class="product-bottom">
            <view class="product-price">
              <text class="price-symbol">¥</text>
              <text class="price-value">{{item.price}}</text>
            </view>
            <view class="product-rating">
              <image class="star-icon" src="/images/icons/star.png" mode="aspectFit"/>
              <text class="rating-text">{{item.rating}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>