.order-detail-container {
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* 状态栏 */
.status-section {
  background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
  border-radius: 16rpx;
  padding: 48rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.status-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 进度条 */
.progress-section {
  margin-bottom: 24rpx;
}

.progress-bar {
  padding: 20rpx 0;
}

.progress-line {
  height: 4rpx;
  background: #EEEEEE;
  border-radius: 2rpx;
  position: relative;
  margin: 20rpx 40rpx 40rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6B4423 0%, #C17817 100%);
  border-radius: 2rpx;
  transition: width 0.5s;
}

.progress-steps {
  display: flex;
  justify-content: space-between;
  padding: 0 20rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.step-dot {
  width: 20rpx;
  height: 20rpx;
  background: #EEEEEE;
  border-radius: 50%;
  margin-bottom: 12rpx;
  position: relative;
}

.step.active .step-dot {
  background: #6B4423;
}

.step.active .step-dot::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #6B4423;
  border-radius: 50%;
}

.step-name {
  font-size: 22rpx;
  color: #999999;
}

.step.active .step-name {
  color: #6B4423;
  font-weight: 500;
}

/* 取餐信息 */
.pickup-section {
  margin-bottom: 24rpx;
}

.pickup-code {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #F5F0EB 0%, #EDE5DC 100%);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.code-label {
  font-size: 28rpx;
  color: #6B4423;
}

.code-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #6B4423;
  letter-spacing: 8rpx;
}

.pickup-info {
  padding-top: 24rpx;
  border-top: 2rpx solid #F5F5F5;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #999999;
}

.info-value {
  font-size: 26rpx;
  color: #333333;
}

/* 商品清单 */
.goods-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.goods-list {
  margin-bottom: 24rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.goods-item:last-child {
  margin-bottom: 0;
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.goods-spec {
  font-size: 22rpx;
  color: #999999;
}

.goods-right {
  text-align: right;
}

.goods-quantity {
  font-size: 24rpx;
  color: #999999;
}

.goods-total {
  display: flex;
  justify-content: space-between;
  padding-top: 24rpx;
  border-top: 2rpx solid #F5F5F5;
  font-size: 26rpx;
  color: #666666;
}

/* 订单信息 */
.info-section {
  margin-bottom: 24rpx;
}

.info-list {
  padding-top: 24rpx;
  border-top: 2rpx solid #F5F5F5;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.item-label {
  width: 140rpx;
  font-size: 26rpx;
  color: #999999;
}

.item-value {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
  word-break: break-all;
}

.copy-btn {
  padding: 8rpx 20rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #666666;
  margin-left: 16rpx;
}

/* 费用明细 */
.fee-section {
  margin-bottom: 24rpx;
}

.fee-list {
  padding-top: 24rpx;
  border-top: 2rpx solid #F5F5F5;
}

.fee-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #666666;
}

.fee-item .discount {
  color: #E54D42;
}

.divider {
  height: 2rpx;
  background: #EEEEEE;
  margin: 24rpx 0;
}

.fee-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fee-total text:first-child {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* 底部占位 */
.bottom-placeholder {
  height: 140rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 120rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0 32rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  padding: 20rpx 40rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  margin-left: 16rpx;
}

.action-btn.default {
  background: #F5F5F5;
  color: #666666;
}

.action-btn.primary {
  background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
  color: #FFFFFF;
}
