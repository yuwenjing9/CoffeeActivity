<view class="pay-result-container">
  <view class="result-icon {{status}}">{{status === 'success' ? '✅' : '❌'}}</view>
  <view class="result-title">{{status === 'success' ? '支付成功' : '支付失败'}}</view>
  <view class="result-desc">{{status === 'success' ? '您的订单已支付成功' : '支付遇到问题，请重试'}}</view>

  <view class="order-info" wx:if="{{status === 'success'}}">
    <view class="info-item">
      <text class="info-label">订单编号</text>
      <text class="info-value">{{orderNo}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">支付金额</text>
      <text class="info-value price">¥{{amount}}</text>
    </view>
  </view>

  <view class="action-btns">
    <view class="btn btn-default" bindtap="goToOrders">查看订单</view>
    <view class="btn btn-primary" bindtap="goToHome">{{status === 'success' ? '返回首页' : '重新支付'}}</view>
  </view>
</view>