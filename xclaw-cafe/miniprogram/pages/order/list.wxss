.order-list-container {
  min-height: 100vh;
  background: #FAF8F5;
}

/* 状态Tab */
.status-tabs {
  background: #FFFFFF;
  margin-bottom: 20rpx;
}

.tabs-scroll {
  white-space: nowrap;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #6B4423;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #6B4423;
  border-radius: 2rpx;
}

.badge {
  min-width: 32rpx;
  height: 32rpx;
  background: #E54D42;
  border-radius: 16rpx;
  color: #FFFFFF;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
  padding: 0 8rpx;
}

/* 订单列表 */
.order-list {
  padding: 0 24rpx;
}

.order-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-no {
  font-size: 24rpx;
  color: #999999;
}

.order-status {
  font-size: 26rpx;
  font-weight: 500;
}

.order-status.pending_payment { color: #E54D42; }
.order-status.making { color: #C17817; }
.order-status.ready { color: #7A9E7E; }
.order-status.completed { color: #999999; }
.order-status.cancelled { color: #999999; }

/* 商品区域 */
.order-goods {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-top: 2rpx solid #F5F5F5;
  border-bottom: 2rpx solid #F5F5F5;
  margin-bottom: 20rpx;
}

.goods-preview {
  display: flex;
  margin-right: 20rpx;
}

.goods-preview image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 12rpx;
}

.goods-preview image:last-child {
  margin-right: 0;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.goods-spec {
  font-size: 22rpx;
  color: #999999;
}

.goods-count {
  font-size: 26rpx;
  color: #666666;
}

/* 订单底部 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-time {
  font-size: 22rpx;
  color: #999999;
}

.order-total {
  display: flex;
  align-items: baseline;
  font-size: 26rpx;
  color: #666666;
}

.order-total .price {
  margin-left: 8rpx;
  color: #333333;
}

/* 操作按钮 */
.order-actions {
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  margin-left: 16rpx;
}

.action-btn.default {
  background: #F5F5F5;
  color: #666666;
}

.action-btn.primary {
  background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
  color: #FFFFFF;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 60rpx;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-state text {
  color: #999999;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.go-shopping {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
}
