<view class="order-list-container">
  <!-- 状态Tab -->
  <view class="status-tabs">
    <scroll-view scroll-x="{{true}}" class="tabs-scroll" show-scrollbar="{{false}}">
      <view class="tab-item {{currentTab === item.status ? 'active' : ''}}" 
            wx:for="{{statusTabs}}" wx:key="status" 
            bindtap="switchTab" data-status="{{item.status}}">
        {{item.name}}
        <view class="badge" wx:if="{{item.count > 0}}">{{item.count > 99 ? '99+' : item.count}}</view>
      </view>
    </scroll-view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="order-header">
        <text class="order-no">订单号: {{item.orderNo}}</text>
        <text class="order-status {{item.status}}">{{item.statusText}}</text>
      </view>
      <view class="order-goods">
        <view class="goods-preview" wx:if="{{item.items.length <= 3}}">
          <image wx:for="{{item.items}}" wx:key="index" src="{{item.image}}" mode="aspectFill"/>
        </view>
        <view class="goods-info" wx:if="{{item.items.length === 1}}">
          <text class="goods-name">{{item.items[0].name}}</text>
          <text class="goods-spec">{{item.items[0].specs}}</text>
        </view>
        <view class="goods-count" wx:if="{{item.items.length > 1}}">
          <text>共{{item.totalCount}}件商品</text>
        </view>
      </view>
      <view class="order-footer">
        <text class="order-time">{{item.createTime}}</text>
        <view class="order-total">
          <text>实付:</text>
          <text class="price price-md">¥{{item.totalAmount}}</text>
        </view>
      </view>
      <view class="order-actions">
        <view class="action-btn default" wx:if="{{item.status === 'pending_payment'}}" catchtap="cancelOrder" data-id="{{item.id}}">取消订单</view>
        <view class="action-btn default" wx:if="{{item.status === 'completed'}}" catchtap="buyAgain" data-items="{{item.items}}">再来一单</view>
        <view class="action-btn primary" wx:if="{{item.status === 'pending_payment'}}" catchtap="payOrder" data-id="{{item.id}}">立即支付</view>
        <view class="action-btn primary" wx:if="{{item.status === 'ready'}}" catchtap="confirmPickup" data-id="{{item.id}}">确认取餐</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{orders.length === 0}}">
    <image src="/images/tabbar/order.png" mode="aspectFit"/>
    <text wx:if="{{currentTab === 'all'}}">暂无订单</text>
    <text wx:if="{{currentTab === 'pending_payment'}}">暂无待支付订单</text>
    <text wx:if="{{currentTab === 'making'}}">暂无制作中订单</text>
    <text wx:if="{{currentTab === 'ready'}}">暂无待取餐订单</text>
    <text wx:if="{{currentTab === 'completed'}}">暂无已完成订单</text>
    <view class="go-shopping" bindtap="goShopping">去逛逛</view>
  </view>
</view>
