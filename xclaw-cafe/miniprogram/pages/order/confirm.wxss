.confirm-container {
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* 取餐方式 */
.delivery-tabs {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666666;
  border-radius: 12rpx;
}

.tab.active {
  background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
  color: #FFFFFF;
  font-weight: 500;
}

/* 地址卡片 */
.address-section {
  margin-bottom: 24rpx;
}

.address-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.address-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.address-main {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.address-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-right: 24rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666666;
}

.address-detail {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

.address-empty {
  padding: 40rpx 0;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}

/* 取餐时间 */
.time-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.time-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.time-value {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666666;
}

/* 商品清单 */
.goods-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.goods-list {
  margin-bottom: 24rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.goods-item:last-child {
  margin-bottom: 0;
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.goods-spec {
  font-size: 22rpx;
  color: #999999;
}

.goods-right {
  text-align: right;
}

.goods-quantity {
  font-size: 24rpx;
  color: #999999;
}

/* 优惠券/备注 */
.coupon-section, .remark-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.section-value {
  display: flex;
  align-items: center;
}

.coupon-text {
  font-size: 26rpx;
  color: #999999;
}

.coupon-text.active {
  color: #E54D42;
}

.remark-input {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #333333;
  margin-left: 24rpx;
}

/* 费用明细 */
.fee-section {
  margin-bottom: 24rpx;
}

.fee-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #666666;
}

.fee-item .discount {
  color: #E54D42;
}

.divider {
  height: 2rpx;
  background: #EEEEEE;
  margin: 24rpx 0;
}

.fee-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fee-total text:first-child {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.total-price {
  color: #E54D42;
}

.arrow {
  color: #999999;
  margin-left: 12rpx;
}

/* 底部占位 */
.bottom-placeholder {
  height: 120rpx;
}

/* 底部提交栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 120rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.05);
}

.total-section {
  flex: 1;
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #333333;
  margin-right: 12rpx;
}

.submit-btn {
  padding: 24rpx 60rpx;
  background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}
