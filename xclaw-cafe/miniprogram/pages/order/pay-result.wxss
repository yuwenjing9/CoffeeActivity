.pay-result-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
  min-height: 100vh;
  background: #FAF8F5;
}

.result-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.result-desc {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 60rpx;
}

.order-info {
  width: 100%;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 60rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
}

.info-value.price {
  color: #E54D42;
  font-weight: bold;
}

.action-btns {
  display: flex;
  width: 100%;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  margin: 0 16rpx;
}

.btn-default {
  background: #F5F5F5;
  color: #666666;
}

.btn-primary {
  background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
  color: #FFFFFF;
}