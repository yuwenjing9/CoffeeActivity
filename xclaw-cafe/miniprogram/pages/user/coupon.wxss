.coupon-container {
  min-height: 100vh;
  background: #FAF8F5;
}

.coupon-tabs {
  display: flex;
  background: #FFFFFF;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab.active {
  color: #6B4423;
  font-weight: 500;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #6B4423;
  border-radius: 2rpx;
}

.coupon-list {
  padding: 0 24rpx;
}

.coupon-item {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  position: relative;
}

.coupon-item.used, .coupon-item.expired {
  opacity: 0.7;
}

.coupon-left {
  width: 200rpx;
  background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  position: relative;
}

.coupon-left::after {
  content: '';
  position: absolute;
  right: -12rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 24rpx;
  height: 24rpx;
  background: #FAF8F5;
  border-radius: 50%;
}

.coupon-value {
  display: flex;
  align-items: baseline;
}

.value-unit {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.value-num {
  font-size: 56rpx;
  font-weight: bold;
}

.coupon-condition {
  font-size: 22rpx;
  margin-top: 8rpx;
}

.coupon-right {
  flex: 1;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
}

.coupon-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.coupon-time, .coupon-scope {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.coupon-status {
  position: absolute;
  right: 32rpx;
  top: 32rpx;
  padding: 8rpx 20rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #999999;
}

.coupon-btn {
  position: absolute;
  right: 32rpx;
  bottom: 32rpx;
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
  color: #FFFFFF;
  border-radius: 28rpx;
  font-size: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 60rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

.empty-state text {
  color: #999999;
  font-size: 28rpx;
}