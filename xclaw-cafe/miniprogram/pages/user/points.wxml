<view class="points-container">
  <view class="points-header">
    <view class="points-title">我的积分</view>
    <view class="points-value">{{userInfo.points || 0}}</view>
    <view class="points-desc">积分可用于兑换优惠券和礼品</view>
  </view>

  <view class="points-tabs">
    <view class="tab {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
    <view class="tab {{currentTab === 'income' ? 'active' : ''}}" bindtap="switchTab" data-tab="income">收入</view>
    <view class="tab {{currentTab === 'expense' ? 'active' : ''}}" bindtap="switchTab" data-tab="expense">支出</view>
  </view>

  <view class="points-list">
    <view class="points-item" wx:for="{{records}}" wx:key="id">
      <view class="points-info">
        <text class="points-reason">{{item.reason}}</text>
        <text class="points-time">{{item.time}}</text>
      </view>
      <text class="points-change {{item.type}}">{{item.type === 'income' ? '+' : '-'}}{{item.points}}</text>
    </view>
  </view>

  <view class="empty-state" wx:if="{{records.length === 0}}">
    <text>暂无记录</text>
  </view>
</view>