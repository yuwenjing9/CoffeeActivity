<view class="favorite-container">
  <!-- 商品列表 -->
  <view class="product-list" wx:if="{{favorites.length > 0}}">
    <view class="product-item" wx:for="{{favorites}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="product-image" src="{{item.image}}" mode="aspectFill"/>
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <text class="product-desc" wx:if="{{item.description}}">{{item.description}}</text>
        <view class="product-bottom">
          <text class="price price-md">¥{{item.price}}</text>
          <view class="product-actions">
            <view class="add-cart-btn" catchtap="addToCart" data-item="{{item}}">加入购物车</view>
            <view class="remove-btn" catchtap="removeFavorite" data-id="{{item.id}}">
              <text class="remove-icon">❤️</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{favorites.length === 0 && !isLoading}}">
    <view class="empty-icon">❤️</view>
    <text>还没有收藏商品</text>
    <view class="empty-action" bindtap="goShopping">
      <text>去逛逛</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{isLoading}}">
    <text>加载中...</text>
  </view>
</view>
