.address-container {
  padding: 24rpx;
  padding-bottom: 160rpx;
  min-height: 100vh;
}

.address-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
}

.address-item.default {
  border-color: #6B4423;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.address-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-right: 24rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666666;
  margin-right: 16rpx;
}

.default-tag {
  padding: 4rpx 16rpx;
  background: rgba(107, 68, 35, 0.1);
  color: #6B4423;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.address-detail {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

.address-actions {
  display: flex;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #F5F5F5;
}

.edit-btn, .delete-btn {
  font-size: 26rpx;
  color: #999999;
  margin-right: 40rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 60rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

.empty-state text {
  color: #999999;
  font-size: 28rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.05);
}

.add-btn {
  height: 88rpx;
  background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
  color: #FFFFFF;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}