.points-container {
  min-height: 100vh;
  background: #FAF8F5;
}

.points-header {
  background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
  padding: 60rpx 40rpx;
  text-align: center;
  color: #FFFFFF;
}

.points-title {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 20rpx;
}

.points-value {
  font-size: 80rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.points-desc {
  font-size: 24rpx;
  opacity: 0.8;
}

.points-tabs {
  display: flex;
  background: #FFFFFF;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab.active {
  color: #6B4423;
  font-weight: 500;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #6B4423;
  border-radius: 2rpx;
}

.points-list {
  padding: 0 24rpx;
}

.points-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.points-info {
  display: flex;
  flex-direction: column;
}

.points-reason {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.points-time {
  font-size: 24rpx;
  color: #999999;
}

.points-change {
  font-size: 32rpx;
  font-weight: bold;
}

.points-change.income {
  color: #7A9E7E;
}

.points-change.expense {
  color: #E54D42;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999999;
  font-size: 28rpx;
}