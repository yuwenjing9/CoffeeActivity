<view class="coupon-container">
  <view class="coupon-tabs">
    <view class="tab {{currentTab === 'available' ? 'active' : ''}}" bindtap="switchTab" data-tab="available">可用</view>
    <view class="tab {{currentTab === 'used' ? 'active' : ''}}" bindtap="switchTab" data-tab="used">已使用</view>
    <view class="tab {{currentTab === 'expired' ? 'active' : ''}}" bindtap="switchTab" data-tab="expired">已过期</view>
  </view>

  <view class="coupon-list">
    <view class="coupon-item {{currentTab}}" wx:for="{{coupons}}" wx:key="id">
      <view class="coupon-left">
        <view class="coupon-value">
          <text class="value-unit">¥</text>
          <text class="value-num">{{item.value}}</text>
        </view>
        <view class="coupon-condition">满{{item.minAmount}}可用</view>
      </view>
      <view class="coupon-right">
        <view class="coupon-name">{{item.name}}</view>
        <view class="coupon-time">有效期至 {{item.expireTime}}</view>
        <view class="coupon-scope">{{item.scope}}</view>
      </view>
      <view class="coupon-status" wx:if="{{currentTab !== 'available'}}">{{currentTab === 'used' ? '已使用' : '已过期'}}</view>
      <view class="coupon-btn" wx:if="{{currentTab === 'available'}}" bindtap="useCoupon" data-item="{{item}}">去使用</view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{coupons.length === 0}}">
    <image src="/images/empty/coupon.png" mode="aspectFit"/>
    <text>暂无{{currentTab === 'available' ? '可用' : currentTab === 'used' ? '已使用' : '已过期'}}优惠券</text>
  </view>
</view>