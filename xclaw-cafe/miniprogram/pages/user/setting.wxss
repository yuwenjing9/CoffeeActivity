.setting-container {
  min-height: 100vh;
  background: #FAF8F5;
  padding: 24rpx;
}

.setting-group {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.setting-item:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 28rpx;
  color: #333333;
}

.item-value {
  font-size: 26rpx;
  color: #999999;
}

.item-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}

.logout-btn {
  margin: 60rpx 0;
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  text-align: center;
  font-size: 30rpx;
  color: #E54D42;
}

.version {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  padding-bottom: 40rpx;
}