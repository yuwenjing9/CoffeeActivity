<view class="center-container">
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="user-bg"></view>
    <view class="user-card">
      <view class="user-info" bindtap="editProfile">
        <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/avatar.png'}}" mode="aspectFill"/>
        <view class="user-meta">
          <text class="user-name">{{userInfo.nickName || '点击登录'}}</text>
          <view class="user-level">
            <text class="level-tag">{{userInfo.level || '普通会员'}}</text>
            <text class="points">{{userInfo.points || 0}} 积分</text>
          </view>
        </view>
        <text class="arrow">></text>
      </view>
      <view class="user-stats">
        <view class="stat-item" bindtap="goToOrders" data-status="all">
          <text class="stat-num">{{stats.orderCount || 0}}</text>
          <text class="stat-label">全部订单</text>
        </view>
        <view class="stat-item" bindtap="goToCoupon">
          <text class="stat-num">{{stats.couponCount || 0}}</text>
          <text class="stat-label">优惠券</text>
        </view>
        <view class="stat-item" bindtap="goToFavorite">
          <text class="stat-num">{{stats.favoriteCount || 0}}</text>
          <text class="stat-label">收藏</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 订单快捷入口 -->
  <view class="order-section card">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <text class="more" bindtap="goToOrders" data-status="all">查看全部 ></text>
    </view>
    <view class="order-types">
      <view class="type-item" bindtap="goToOrders" data-status="pending_payment">
        <view class="type-icon">💰</view>
        <text class="type-name">待支付</text>
        <view class="type-badge" wx:if="{{stats.pendingCount > 0}}">{{stats.pendingCount}}</view>
      </view>
      <view class="type-item" bindtap="goToOrders" data-status="making">
        <view class="type-icon">☕</view>
        <text class="type-name">制作中</text>
        <view class="type-badge" wx:if="{{stats.makingCount > 0}}">{{stats.makingCount}}</view>
      </view>
      <view class="type-item" bindtap="goToOrders" data-status="ready">
        <view class="type-icon">📦</view>
        <text class="type-name">待取餐</text>
        <view class="type-badge" wx:if="{{stats.readyCount > 0}}">{{stats.readyCount}}</view>
      </view>
      <view class="type-item" bindtap="goToOrders" data-status="completed">
        <view class="type-icon">✅</view>
        <text class="type-name">已完成</text>
        <view class="type-badge" wx:if="{{stats.successCount > 0}}">{{stats.successCount}}</view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section card">
    <view class="menu-item" bindtap="goToAddress">
      <view class="menu-left">
        <text class="menu-icon">📍</text>
        <text class="menu-name">收货地址</text>
      </view>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToCoupon">
      <view class="menu-left">
        <text class="menu-icon">🎫</text>
        <text class="menu-name">优惠券</text>
      </view>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToPoints">
      <view class="menu-left">
        <text class="menu-icon">🎁</text>
        <text class="menu-name">积分商城</text>
      </view>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="contactService">
      <view class="menu-left">
        <text class="menu-icon">💬</text>
        <text class="menu-name">联系客服</text>
      </view>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 其他功能 -->
  <view class="menu-section card">
    <view class="menu-item" bindtap="goToSetting">
      <view class="menu-left">
        <text class="menu-icon">⚙️</text>
        <text class="menu-name">设置</text>
      </view>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="aboutUs">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-name">关于我们</text>
      </view>
      <text class="arrow">></text>
    </view>
  </view>
</view>
