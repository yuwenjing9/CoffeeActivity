.product-list-container {
  min-height: 100vh;
  background: #FAF8F5;
  padding-bottom: 140rpx;
}

/* 搜索栏 */
.search-header {
  padding: 20rpx 32rpx;
  background: #FFFFFF;
}

.search-bar {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #F5F5F5;
  border-radius: 36rpx;
  padding: 0 32rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

/* 分类Tab */
.category-tabs {
  background: #FFFFFF;
  padding: 0 32rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.tabs-scroll {
  white-space: nowrap;
}

.tab-item {
  display: inline-flex;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #6B4423;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #6B4423;
  border-radius: 2rpx;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #FFFFFF;
  margin-bottom: 20rpx;
}

.sort-item {
  display: flex;
  align-items: center;
  margin-right: 48rpx;
  font-size: 26rpx;
  color: #666666;
}

.sort-item.active {
  color: #6B4423;
  font-weight: 500;
}

.sort-arrow {
  margin-left: 8rpx;
  font-size: 22rpx;
}

/* 商品网格 */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 24rpx;
}

.product-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.product-image {
  width: 100%;
  height: 340rpx;
}

.product-info {
  padding: 20rpx;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.product-tags .tag {
  padding: 4rpx 12rpx;
  background: rgba(107, 68, 35, 0.1);
  color: #6B4423;
  border-radius: 8rpx;
  font-size: 20rpx;
  margin-right: 8rpx;
}

.product-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-sales {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.add-btn {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 35rpx;
  font-weight: bold;
  line-height: 40rpx;
  text-align: center;
}

/* 加载状态 */
.load-more, .no-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: #999999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 60rpx;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-state text {
  color: #999999;
  font-size: 28rpx;
}

/* 悬浮购物车 */
.float-cart {
  position: fixed;
  right: 32rpx;
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  background: #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.float-cart.has-items {
  background: linear-gradient(135deg, #6B4423 0%, #8B5A3C 100%);
}

.cart-icon-wrapper {
  position: relative;
}

.cart-icon {
  font-size: 48rpx;
}

.float-cart.has-items .cart-icon {
  color: #FFFFFF;
}

.cart-badge {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #E54D42;
  border-radius: 16rpx;
  color: #FFFFFF;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}
