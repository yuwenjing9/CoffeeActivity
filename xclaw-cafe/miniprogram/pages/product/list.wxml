<view class="product-list-container">
  <!-- 搜索栏 -->
  <view class="search-header">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input class="search-input" 
             placeholder="搜索咖啡、茶饮" 
             value="{{searchKeyword}}"
             bindinput="onSearchInput"
             confirm-type="search"/>
      <view class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">
        <text>✕</text>
      </view>
    </view>
  </view>

  <!-- 分类Tab -->
  <view class="category-tabs">
    <scroll-view scroll-x="{{true}}" class="tabs-scroll" show-scrollbar="{{false}}">
      <view class="tab-item {{currentCategory === item.id ? 'active' : ''}}" 
            wx:for="{{categories}}" wx:key="id" 
            bindtap="switchCategory" data-id="{{item.id}}">
        {{item.name}}
      </view>
    </scroll-view>
  </view>

  <!-- 排序筛选 -->
  <view class="sort-bar">
    <view class="sort-item {{sortType === 'default' ? 'active' : ''}}" bindtap="changeSort" data-type="default">综合排序</view>
    <view class="sort-item {{sortType === 'sales' ? 'active' : ''}}" bindtap="changeSort" data-type="sales">销量优先</view>
    <view class="sort-item {{sortType === 'price' ? 'active' : ''}}" bindtap="changeSort" data-type="price">
      价格
      <text class="sort-arrow">{{priceAsc ? '↑' : '↓'}}</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="product-grid">
    <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="product-image" src="{{item.image}}" mode="aspectFill" lazy-load="{{true}}"/>
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <text class="product-desc" wx:if="{{item.description}}">{{item.description}}</text>
        <text class="product-sales">月售 {{item.sales}}</text>
        <view class="product-bottom">
          <text class="price price-md">¥{{item.price}}</text>
          <view class="add-btn" catchtap="addToCart" data-item="{{item}}">+</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{isLoading}}">加载中...</view>
  <view class="no-more" wx:if="{{!hasMore && products.length > 0}}">没有更多了</view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{products.length === 0 && !isLoading}}">
    <view class="empty-icon">🔍</view>
    <text>{{searchKeyword ? '未找到相关商品' : '暂无商品'}}</text>
    <view class="empty-action" wx:if="{{searchKeyword}}" bindtap="clearSearch">
      <text>清空搜索</text>
    </view>
  </view>
</view>

<!-- 悬浮购物车 -->
<view class="float-cart {{cartCount > 0 ? 'has-items' : ''}}" bindtap="goToCart">
  <view class="cart-icon-wrapper">
    <text class="cart-icon">🛒</text>
    <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount > 99 ? '99+' : cartCount}}</view>
  </view>
</view>
