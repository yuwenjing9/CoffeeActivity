<view class="detail-container">
  <!-- 商品图片 -->
  <view class="product-image-section">
    <image class="product-image" src="{{product.image}}" mode="aspectFill"/>
  </view>

  <!-- 商品信息卡片 -->
  <view class="product-info-card">
    <view class="product-name">{{product.name}}</view>
    
    <!-- 评分和销量 -->
    <view class="product-stats">
      <view class="stat-item">
        <image class="star-icon" src="/images/icons/star.png" mode="aspectFit"/>
        <text class="stat-text">{{product.rating}}</text>
      </view>
      <text class="stat-divider">|</text>
      <text class="stat-text">月售{{product.sales}}</text>
    </view>

    <!-- 价格 -->
    <view class="product-price">
      <text class="price-symbol">¥</text>
      <text class="price-value">{{product.price}}</text>
      <text class="original-price" wx:if="{{product.originalPrice > product.price}}">¥{{product.originalPrice}}</text>
    </view>
  </view>

  <!-- 商品描述（放在选择属性上方） -->
  <view class="section-card">
    <view class="section-title">商品描述</view>
    <view class="section-content">{{product.description}}</view>
  </view>

  <!-- 温度选择 -->
  <view class="section-card">
    <view class="section-title">温度</view>
    <view class="option-group">
      <view class="option-item {{selectedTemp === 'hot' ? 'active' : ''}}" 
            bindtap="selectTemp" data-value="hot">热饮</view>
      <view class="option-item {{selectedTemp === 'cold' ? 'active' : ''}}" 
            bindtap="selectTemp" data-value="cold">冰饮</view>
    </view>
  </view>

  <!-- 杯型选择 -->
  <view class="section-card">
    <view class="section-title">杯型</view>
    <view class="option-group">
      <view class="option-item {{selectedSize === 'small' ? 'active' : ''}}" 
            bindtap="selectSize" data-value="small">
        <text>小杯</text>
      </view>
      <view class="option-item {{selectedSize === 'medium' ? 'active' : ''}}" 
            bindtap="selectSize" data-value="medium">
        <text>中杯</text>
        <text class="option-extra">+¥3</text>
      </view>
      <view class="option-item {{selectedSize === 'large' ? 'active' : ''}}" 
            bindtap="selectSize" data-value="large">
        <text>大杯</text>
        <text class="option-extra">+¥6</text>
      </view>
    </view>
  </view>

  <!-- 糖度选择 -->
  <view class="section-card">
    <view class="section-title">糖度</view>
    <view class="option-group">
      <view class="option-item {{selectedSugar === 'none' ? 'active' : ''}}" 
            bindtap="selectSugar" data-value="none">不加糖</view>
      <view class="option-item {{selectedSugar === 'little' ? 'active' : ''}}" 
            bindtap="selectSugar" data-value="little">少糖</view>
      <view class="option-item {{selectedSugar === 'standard' ? 'active' : ''}}" 
            bindtap="selectSugar" data-value="standard">标准</view>
      <view class="option-item {{selectedSugar === 'more' ? 'active' : ''}}" 
            bindtap="selectSugar" data-value="more">多糖</view>
    </view>
  </view>

  <!-- 数量选择 -->
  <view class="section-card">
    <view class="section-title">数量</view>
    <view class="quantity-selector">
      <view class="quantity-btn {{quantity <= 1 ? 'disabled' : ''}}" 
            bindtap="decreaseQuantity">-</view>
      <text class="quantity-value">{{quantity}}</text>
      <view class="quantity-btn add" bindtap="increaseQuantity">+ </view>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-placeholder"></view>
</view>

<!-- 底部操作栏 -->
<view class="bottom-bar">
  <!-- 购物车入口 -->
  <view class="cart-entry" bindtap="goToCart">
    <image class="cart-icon" src="/images/tabbar/cart.png" mode="aspectFit"/>
    <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount > 99 ? '99+' : cartCount}}</view>
    <text class="cart-label">购物车</text>
  </view>

  <!-- 加购按钮 -->
  <view class="add-cart-btn" bindtap="addToCart">
    <image class="btn-icon" src="/images/icons/cart.png" mode="aspectFit"/>
    <text class="btn-text">加购</text>
  </view>

  <!-- 立即购买按钮 -->
  <view class="buy-btn" bindtap="buyNow">
    <text class="btn-text">立即购买</text>
  </view>
</view>
