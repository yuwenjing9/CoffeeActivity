.pf-page {
  padding-top: 24rpx;
  padding-bottom: 80rpx;
}

.pf-user {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFD7BE 0%, var(--primary) 100%);
  color: #fff;
  padding: 36rpx 28rpx;
}

.pf-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  overflow: hidden;
}

.pf-img {
  width: 100%;
  height: 100%;
}

.pf-emoji {
  font-size: 60rpx;
}

/* 头像按钮（chooseAvatar 触发） */
.pf-avatar-btn {
  position: relative;
  width: 110rpx !important;
  height: 110rpx;
  padding: 0 !important;
  margin: 0 24rpx 0 0 !important;
  background: transparent !important;
  border: none !important;
  line-height: 1 !important;
  border-radius: 50%;
}

.pf-avatar-btn::after {
  border: none;
}

.pf-avatar-btn .pf-avatar {
  margin-right: 0;
}

.pf-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.pf-meta {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.flex-1 {
  flex: 1;
}

.pf-group {
  margin-top: 32rpx;
}

.pf-group-title {
  font-size: 24rpx;
  color: #9C948D;
  padding: 0 12rpx 12rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F4F1EC;
}

.row.no-bd {
  border-bottom: none;
}

.row-k {
  font-size: 28rpx;
  color: #1F1B16;
}

.row-sub {
  font-size: 24rpx;
  color: #9C948D;
}

.row-arrow {
  color: #9C948D;
  font-size: 36rpx;
  margin-left: 10rpx;
}

.flex-row {
  display: flex;
  align-items: center;
}

.logout {
  margin: 60rpx 32rpx 0;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
  color: var(--danger);
}